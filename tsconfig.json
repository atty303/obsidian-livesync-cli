{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020"
    ],
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "obsidian-livesync/*": [
        "vendor/obsidian-livesync/src/*"
      ]
    }
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "vendor"
  ],
  "references": [
    {
      "path": "tsconfig.obsidian-livesync.json"
    }
  ]
}
